# ===============================
#  .gitignore - Secure Account Manager
# ===============================

# --- PyInstaller ---
build/
dist/
*.spec

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
pip-wheel-metadata/

# --- Ambienti virtuali ---
venv/
.venv/
env/
.env/

# --- Vault e dati sensibili ---
*.dat
vault.dat

# --- IDE ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- Sistema operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- Log ---
*.log